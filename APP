NUM_SERVOS = 5

NOMBRES_SERVOS = ["Base", "Hombro", "Codo", "Muñeca", "Pinza"]
LIMITES_SERVOS = [(0,180), (0,180), (0,180), (0,180), (0,90)]
VALORES_INICIALES = [90,90,90,90,45]
SLIDER_DEBOUNCE_MS = 80
RECONNECT_MS = 2000

BG_MAIN = "#000000"
BG_PANEL = "#101010"
BG_WIDGET = "#1b1b1b"
